# Friends / LAN demo — copy to .env and fill in.
# See docs/FRIENDS_DEMO.md for the full checklist.

# Bind for LAN/VPS sharing (loopback DIY: leave unset / 127.0.0.1)
SCENIC_BIND_HOST=0.0.0.0

# Enables API-key gate (also auto-on when BIND_HOST is non-loopback)
SCENIC_PUBLIC=1

# Shared secret friends enter as "Host key" in the UI
SCENIC_API_KEY=change-me-to-a-long-random-string

# Per-IP requests per minute (plan + geocode + save, etc.)
SCENIC_RATE_LIMIT_PER_MIN=30

# Soft wall-clock budget for one plan (seconds)
SCENIC_PLAN_BUDGET_SEC=30

# Cap concurrent plans so two friends don't melt the host (default 2)
SCENIC_MAX_INFLIGHT_PLANS=2

# Optional: bring-your-own OSRM-compatible router (leave unset = public OSRM)
# SCENIC_OSRM_URL=http://127.0.0.1:5000/route/v1/driving/{coords}
